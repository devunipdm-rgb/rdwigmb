{
  "name": "rdwigmb",
  "build": {
    "command": "npm install",
    "start": "npm start",
    "output": "server.js"
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ],
  "env": {
    "NODE_VERSION": "18"
  },
  "functions": {
    "server.js": {
      "runtime": "nodejs18.x"
    }
  }
}
